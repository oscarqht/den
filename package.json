{
  "name": "den-ai",
  "version": "1.11.0",
  "private": false,
  "description": "Den is a local control center for AI coding work. It gives every task its own isolated workspace, so agents can work in parallel, stay organized, and make changes you can review with confidence.",
  "repository": {
    "type": "git",
    "url": "https://github.com/m0o0scar/den"
  },
  "bin": {
    "den-ai": "bin/viba.mjs"
  },
  "files": [
    "bin",
    "src/lib/cli-args.mjs",
    "src/lib/next-native-shims.mjs",
    ".next/BUILD_ID",
    ".next/server",
    ".next/static",
    ".next/*.json",
    ".next/*.js",
    "public",
    "next.config.mjs",
    "README.md"
  ],
  "scripts": {
    "dev": "node ./bin/viba.mjs --dev",
    "kill": "node ./scripts/kill-next-dev.mjs",
    "list": "sh -c 'lsof -nP -iTCP:3200-3299 -sTCP:LISTEN || echo \"No listening processes on 32xx ports\"'",
    "tailscale": "node ./scripts/tailscale.mjs",
    "tailscale:stop": "node ./scripts/tailscale.mjs stop",
    "build": "next build",
    "postbuild": "node ./scripts/copy-next-shims.mjs",
    "build:webpack": "next build --webpack",
    "prepack": "node -e \"require('node:fs').rmSync('.next',{recursive:true,force:true})\" && npm run build",
    "start": "node ./bin/viba.mjs",
    "tunnel": "node ./scripts/tunnel-restart.mjs 3200 -s palx",
    "tunnel:once": "nport 3200 -s palx",
    "lint": "eslint",
    "test": "node --experimental-strip-types --test src/**/*.test.ts test/**/*.test.mjs",
    "cli": "node ./bin/viba.mjs",
    "pack:preview": "npm pack --dry-run"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "git-worktree",
    "nextjs"
  ],
  "license": "MIT",
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.15.0",
    "@alexbruf/react-diff-viewer": "^3.1.5",
    "@auth0/nextjs-auth0": "^4.16.0",
    "@tanstack/react-query": "^5.90.21",
    "@types/uuid": "^10.0.0",
    "clsx": "^2.1.1",
    "daisyui": "^5.5.18",
    "gfport": "^1.0.1",
    "http-proxy-middleware": "^3.0.5",
    "keytar": "^7.9.0",
    "lucide-react": "^0.563.0",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.30.0",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/ws": "^8.18.1",
    "eslint": "^10.1.0",
    "eslint-config-next": "^0.2.4",
    "nport": "^2.1.4",
    "tailwindcss": "^4",
    "typescript": "5.9.3"
  },
  "overrides": {
    "prebuild-install": "npm:@scrypted/prebuild-install@7.1.10"
  }
}
